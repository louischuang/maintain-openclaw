# Copy this file to .env and replace values with your private environment.
# Never commit .env.

# Test VM used for OpenClaw install/remove/status checks.
OPENCLAW_TEST_VM_USER=your-user
OPENCLAW_TEST_VM_HOST=192.0.2.10
OPENCLAW_TEST_VM_SSH_TARGET=${OPENCLAW_TEST_VM_USER}@${OPENCLAW_TEST_VM_HOST}

# OpenClaw gateway port used by removal/status scripts.
OPENCLAW_GATEWAY_PORT=18789

# OpenClaw install options.
OPENCLAW_NPM_VERSION=latest
OPENCLAW_WORKSPACE_DIR=${HOME}/.openclaw/workspace
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_GATEWAY_AUTH=none
OPENCLAW_INSTALL_SERVICE=false
OPENCLAW_START_GATEWAY=false

# Ollama provider reachable from the VM.
# Use the host-visible address, not 127.0.0.1, when Ollama runs on your Mac.
OPENCLAW_OLLAMA_BASE_URL=http://192.0.2.20:11434
OPENCLAW_OLLAMA_MODEL=gemma4:26b
OPENCLAW_OLLAMA_PROVIDER_ID=local-ollama
OPENCLAW_OLLAMA_TIMEOUT_SECONDS=600
